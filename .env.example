# ============================================
# JuroCerto Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================
# AI & API CONFIGURATION (REQUIRED)
# ============================================
# Get your GEMINI_API_KEY from: https://ai.google.dev/
# Generate JUROCERTO_API_KEY: openssl rand -hex 32
GEMINI_API_KEY="your-google-gemini-api-key-here"
JUROCERTO_API_KEY="your-secure-bearer-token-here"

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV="development"
# Allowed values: development | production | test

HOST="localhost"
# For development: localhost (recommended for security)
# For production: 0.0.0.0 only with reverse proxy/firewall

PORT="3000"
# Server port (must be available)

LOG_LEVEL="info"
# Allowed values: debug | info | warn | error

# ============================================
# SECURITY & CORS
# ============================================
# Production: Set to your domain(s)
# Development: Auto-allows localhost:3000, localhost:5173, 127.0.0.1:*
ALLOWED_ORIGINS="https://jurocerto.com,https://app.jurocerto.com"

# ============================================
# APPLICATION URL (Optional, for docs/links)
# ============================================
APP_URL="https://jurocerto.com"

